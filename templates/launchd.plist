<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.{{AGENT_ID}}.bridge</string>

    <key>ProgramArguments</key>
    <array>
        <string>{{WORKSPACE_PATH}}/.bot/.venv/bin/python3</string>
        <string>{{WORKSPACE_PATH}}/.bot/bridge.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>{{WORKSPACE_PATH}}/.bot</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>15</integer>

    <key>StandardOutPath</key>
    <string>{{WORKSPACE_PATH}}/.bot/bridge.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>{{WORKSPACE_PATH}}/.bot/bridge.stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>{{HOME}}/.local/bin:{{WORKSPACE_PATH}}/.bot/.venv/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
